GOOGLE_GENAI_USE_VERTEXAI=False
GOOGLE_API_KEY="INSERT_YOUR_AI_STUDIO_KEY_HERE"
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# --- Cloud Run deployment (scripts/deploy_agent.py --target cloud_run) ---
# Service account email the Cloud Run service runs as. Required for init + deploy.
CLOUD_RUN_SERVICE_ACCOUNT=

# --- STRIDE Self-Healing (issue #16) — Three-layer surface control ---
# Master kill-switch. Disabled by default; no LLM calls or file writes occur when false.
STRIDE_SELF_HEALING_ENABLED=false

# Arbitrator surface: controls direct CLI invocation (`arbitrator stride-heal`).
STRIDE_SELF_HEALING_ARBITRATOR_ENABLED=true

# [EXPERIMENTAL] Ambient surface: event-driven background observer.
# When true, the supervisor activates after each coding/stride agent run.
STRIDE_SELF_HEALING_AMBIENT_ENABLED=false

# Escalating autonomy ladder:
#   audit_only    — print STRIDE report only, no writes
#   propose_patch — generate and print patch, no writes
#   apply_patch   — write patch + run pytest locally
#   open_pr       — apply_patch + open a PR to develop
STRIDE_SELF_HEALING_MODE=audit_only

# --- Quality Flywheel (issue #18) — Three-layer surface control ---
# Master kill-switch. Disabled by default; no LLM calls or file writes occur when false.
QUALITY_FLYWHEEL_ENABLED=false

# Arbitrator surface: controls direct CLI invocation (`arbitrator flywheel`).
QUALITY_FLYWHEEL_ARBITRATOR_ENABLED=true

# [EXPERIMENTAL] Ambient surface: event-driven background observer.
# When true, the supervisor checks telemetry for violations after each agent run.
QUALITY_FLYWHEEL_AMBIENT_ENABLED=false

# Optimization mode label for experimental surfaces.
# Current CLI behavior: when enabled and triggered, `arbitrator flywheel`
# writes a few-shot, validates routing, and opens a PR unless --dry-run is used.
# Current ambient behavior: observes telemetry and logs violations only.
QUALITY_FLYWHEEL_MODE=observe_only

# GitHub integration placeholders for deployment wrappers.
# Current local PR creation uses the authenticated `gh` CLI; these values are not read directly.
GITHUB_INTEGRATION_ENABLED=false
GITHUB_TOKEN=
